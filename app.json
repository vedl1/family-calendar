{
  "expo": {
    "name": "Family Calendar",
    "slug": "family-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "family-calendar",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vedluhana.familycalendar"
    },
    "android": {
      "package": "com.vedluhana.familycalendar",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app uses your photos for your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
